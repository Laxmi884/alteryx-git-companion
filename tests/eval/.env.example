# Copy this file to tests/eval/.env and fill in your values.
# The eval script loads this automatically if python-dotenv is installed:
#   pip install python-dotenv

# Generator: the model that writes the documentation
ACD_LLM_MODEL=openrouter:anthropic/claude-sonnet-4-5

# Critic: independent model that judges faithfulness (recommended: gpt-4o)
RAGAS_CRITIC_MODEL=openrouter:openai/gpt-4o

# API key for OpenRouter (covers both generator and critic if using openrouter:)
OPENROUTER_API_KEY=your-key-here
