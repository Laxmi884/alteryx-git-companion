<?xml version="1.0"?>
<AlteryxDocument yxmdVer="2020.1">
  <Nodes>
    <Node ToolID="1">
      <GuiSettings Plugin="AlteryxBasePluginsGui.DbFileInput.DbFileInput">
        <Position x="54" y="54"/>
      </GuiSettings>
      <Properties>
        <Configuration>
          <File>C:\Data\sales_2023.csv</File>
          <RecordLimit>0</RecordLimit>
          <SearchSubDirs>False</SearchSubDirs>
          <FileFormat>0</FileFormat>
        </Configuration>
        <Annotation DisplayMode="0">
          <Name>Input: Sales 2023</Name>
