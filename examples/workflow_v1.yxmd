            <Field field="Sales" selected="True"/>
            <Field field="Date" selected="True"/>
            <Field field="Notes" selected="False"/>
          </Fields>
        </Configuration>
        <Annotation DisplayMode="0">
          <Name>Select Fields</Name>
        </Annotation>
      </Properties>
      <EngineSettings EngineDll="AlteryxBasePlugins.dll" EngineDllEntryPoint="AlteryxSelect"/>
