        <Annotation DisplayMode="0">
          <Name>Sum by Region</Name>
        </Annotation>
      </Properties>
      <EngineSettings EngineDll="AlteryxBasePlugins.dll" EngineDllEntryPoint="AlteryxSummarize"/>
