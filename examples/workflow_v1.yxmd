    <Node ToolID="2">
      <GuiSettings Plugin="AlteryxBasePluginsGui.Filter.Filter">
        <Position x="198" y="54"/>
      </GuiSettings>
      <Properties>
        <Configuration>
          <Expression>[Region] = "North"</Expression>
